# ImpacTracer Environment Configuration
# Copy this file to .env and fill in your API key.

# LLM Provider (OpenRouter or direct OpenAI)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_SEED=42

# Embedding and Reranking Models (local inference)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_BATCH_SIZE=32

# Storage Paths (local, zero managed services)
DB_PATH=./data/impactracer.db
CHROMA_PATH=./data/chroma_store

# Indexer
TOP_K_TRACEABILITY=5

# Retrieval
MAX_CANDIDATES_POST_RRF=15
MAX_CANDIDATES_POST_RERANK=15
RRF_K=60

# BFS
BFS_GLOBAL_MAX_DEPTH=3
BFS_SINGLE_HOP_EDGES=IMPORTS,DEPENDS_ON_EXTERNAL,RENDERS

# Context Window
LLM_MAX_CONTEXT_TOKENS=100000
